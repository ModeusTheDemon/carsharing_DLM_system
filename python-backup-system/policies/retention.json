{
  "healthcheck_policy": {
    "healthcheck_every_minutes": 5
  },

  "save_inc_policy": {
    "save_inc_every_weeks": 1
  },

  "save_full_policy": {
    "save_full_every_months": 1
  },

  "scheduling": {
